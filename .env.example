# ─── Core ────────────────────────────────────────────────────────────────────
# Default LLM provider key (used when no provider config is stored in the DB).
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Supabase auth (REQUIRED) ────────────────────────────────────────────────
# Backend verifies bearer JWTs against this project. The same two values are
# ALSO baked into the frontend bundle at build time as VITE_SUPABASE_* (the
# docker-compose build maps SUPABASE_* → VITE_SUPABASE_*). Without them the SPA
# renders a blank page.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# Comma-separated allow-list. The FIRST entry is the household "founder".
ALLOWED_EMAILS=you@example.com

# ─── CORS ────────────────────────────────────────────────────────────────────
# Origin allowed to call the API with credentials. Defaults in code to the
# lumi-server domain — set this when deploying anywhere else.
ALLOWED_ORIGIN=https://meal-planner.lumi-server.dev

# ─── Optional alternative LLM providers ──────────────────────────────────────
# Used only as env fallbacks if a provider config isn't stored in the DB.
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# ─── Shopping / e-commerce integrations (optional) ───────────────────────────
INSTACART_API_KEY=your_instacart_key_here
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# ─── Recipe images (optional) ────────────────────────────────────────────────
PEXELS_API_KEY=

# ─── WebAuthn / passkeys ─────────────────────────────────────────────────────
# RP ID is the registrable domain; ORIGIN is the full https origin.
PASSKEY_RP_ID=meal-planner.lumi-server.dev
PASSKEY_ORIGIN=https://meal-planner.lumi-server.dev

# ─── External read API (Goblin Calendar) ─────────────────────────────────────
# Shared bearer token for /api/external/v1/*. Must match SNACK_GOBLIN_TOKEN in
# the Goblin Calendar deployment.
INTEGRATION_TOKEN=

# ─── Storage ─────────────────────────────────────────────────────────────────
# SQLite path (defaults to /data/meal-planner.db in the container).
DB_PATH=/data/meal-planner.db

# ─── Mobile app (mobile/.env) ────────────────────────────────────────────────
# EXPO_PUBLIC_API_URL=https://meal-planner.lumi-server.dev
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

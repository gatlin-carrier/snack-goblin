{
  "expo": {
    "name": "Snack Goblin",
    "slug": "snack-goblin",
    "scheme": "snack-goblin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF0E6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.snackgoblin",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Snack Goblin uses the camera to scan barcodes and receipts.",
        "NSFaceIDUsageDescription": "Snack Goblin uses Face ID to sign in quickly without a password."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF0E6"
      },
      "package": "app.snackgoblin",
      "versionCode": 1,
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "server"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-apple-authentication"
    ]
  }
}
